﻿@{
    ViewBag.Title = "帖子封禁管理";
    Layout = "~/Views/Shared/_GuanLi.cshtml";
}
@section styles {
    <link href="~/CSS/GongGong/DengLu/DengLuGongGong.css" rel="stylesheet" />
    <link href="~/CSS/GuanLi/FengJin.css" rel="stylesheet" />
}

<div class="guanli-rongqi" id="fengjin-app" v-cloak>
    <div class="mo-kuai-biao-ti">
        <h2>帖子封禁管理</h2>
        <div class="fu-biao-ti">管理帖子上下架状态</div>
    </div>

    <div class="sousuo-qu">
        <input type="text" class="sousuo-shuru" placeholder="帖子标题" v-model="tieZiMing" @@keyup.enter="souSuo" />
        <input type="text" class="sousuo-shuru" placeholder="帖子ID" v-model="tieZiID" @@keyup.enter="souSuo" />
        <button class="pagination-input" @@click="souSuo">搜索</button>
        <button class="pagination-input" @@click="qingKong">清空</button>
    </div>

    <div class="table-wrapper" :style="{ minHeight: firstLoad ? '480px' : '400px' }">
        <div v-if="firstLoad" class="loading-container" style="min-height:480px">
            <div class="loading-spinner"></div>
            <p class="loading-text">加载中，请稍候...</p>
        </div>
        <template v-else>
            <table class="biao-ge">
                <thead>
                    <tr><th>ID</th><th>标题</th><th>作者</th><th>发布时间</th><th>状态</th><th>操作</th></tr>
                </thead>
                <tbody>
                    <tr v-for="item in list" :key="item.TieZiID">
                        <td>{{ item.TieZiID }}</td>
                        <td>{{ item.TieZiMing }}</td>
                        <td>{{ item.YongHuMing }}</td>
                        <td>{{ item.FaBuShiJian | dateFormat('yyyy年MM月dd日 HH:mm') }}</td>
                        <td :class="item.ZhuangTai == 1 ? 'zheng-chang' : 'feng-jin'">
                            {{ item.ZhuangTai == 1 ? '正常' : (item.ZhuangTai == 2 ? '已删除' : '封禁') }}
                        </td>
                        <td>
                            <button v-if="item.ZhuangTai == 1" class="pagination-input" @@click="kaiQiFengJin(item)">封禁</button>
                            <button v-else-if="item.ZhuangTai == 2" class="pagination-input" disabled>解封</button>
                            <button v-else class="pagination-input" @@click="kaiQiJieFeng(item)">解封</button>
                        </td>
                    </tr>
                </tbody>
            </table>
            <div v-if="list.length === 0" class="no-data">暂无帖子数据</div>
        </template>
    </div>

    <div id="FanYe" v-if="!firstLoad">
        <div class="pagination">
            <input type="button" value="首页" class="pagination-input" :disabled="page <= 1" @@click="huanYe(1)" />
            <input type="button" value="上一页" class="pagination-input" :disabled="page <= 1" @@click="huanYe(page - 1)" />
            <span>第 {{ page }} / {{ totalPages }} 页</span>
            <input type="button" value="下一页" class="pagination-input" :disabled="page >= totalPages" @@click="huanYe(page + 1)" />
            <input type="button" value="尾页" class="pagination-input" :disabled="page >= totalPages" @@click="huanYe(totalPages)" />
        </div>
    </div>

    <!-- 封禁确认模态框 -->
    <div class="mo-tai-zhe-zhao" v-if="showFengJinModal" @@click.self="guanBiFengJinMoTai">
        <div class="mo-tai-ka-pian">
            <h3>确认封禁</h3>
            <p><strong>帖子ID：</strong> {{ currentFengJinItem.TieZiID }}</p>
            <p><strong>标题：</strong> {{ currentFengJinItem.TieZiMing }}</p>
            <div>
                <label>封禁原因：</label>
                <input type="text" class="mo-tai-shuru" v-model="fengJinYuanYin" placeholder="请输入封禁原因" />
            </div>
            <div class="mo-tai-an-niu">
                <button class="pagination-input" @@click="guanBiFengJinMoTai">取消</button>
                <button class="pagination-input" @@click="zhiXingFengJin">确认封禁</button>
            </div>
        </div>
    </div>

    <!-- 解封确认模态框 -->
    <div class="mo-tai-zhe-zhao" v-if="showJieFengModal" @@click.self="guanBiJieFengMoTai">
        <div class="mo-tai-ka-pian">
            <h3>确认解封</h3>
            <p><strong>帖子ID：</strong> {{ currentJieFengItem.TieZiID }}</p>
            <p><strong>标题：</strong> {{ currentJieFengItem.TieZiMing }}</p>
            <p style="color:#8fbedc;">确定要将该帖子恢复上架吗？</p>
            <div class="mo-tai-an-niu">
                <button class="pagination-input" @@click="guanBiJieFengMoTai">取消</button>
                <button class="pagination-input" @@click="zhiXingJieFeng">确认解封</button>
            </div>
        </div>
    </div>

    <!-- 消息提示模态框 -->
    <div class="mo-tai-zhe-zhao" v-if="showMessageModal" @@click.self="guanBiXiaoXiMoTai">
        <div class="mo-tai-ka-pian">
            <h3>提示</h3>
            <p style="margin:15px 0; word-break:break-all;">{{ messageText }}</p>
            <div class="mo-tai-an-niu" style="justify-content:center;">
                <button class="pagination-input" @@click="guanBiXiaoXiMoTai">确定</button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.bootcdn.net/ajax/libs/vue/2.6.14/vue.min.js"></script>
<script>
    new Vue({
        el: '#fengjin-app',
        data: {
            list: [],
            page: 1,
            pageSize: 5,
            total: 0,
            totalPages: 1,
            tieZiMing: '',
            tieZiID: '',
            showFengJinModal: false,
            showJieFengModal: false,
            currentFengJinItem: {},
            currentJieFengItem: {},
            fengJinYuanYin: '',
            firstLoad: true,
            showMessageModal: false,
            messageText: ''
        },
        filters: {
            dateFormat: function (value, format) {
                if (!value) return '';
                var date;
                date = new Date(value);
                if (isNaN(date.getTime())) {
                    var str = value.toString();
                    var isPM = /PM/i.test(str);
                    str = str.replace(/\s*AM|PM/gi, '');
                    var parts = str.split(/[\s/:]+/);
                    if (parts.length >= 3) {
                        var month = parseInt(parts[0]) - 1;
                        var day = parseInt(parts[1]);
                        var year = parseInt(parts[2]);
                        var hour = parts.length >= 4 ? parseInt(parts[3]) : 0;
                        var minute = parts.length >= 5 ? parseInt(parts[4]) : 0;
                        var second = parts.length >= 6 ? parseInt(parts[5]) : 0;
                        if (isPM && hour < 12) hour += 12;
                        if (!isPM && hour === 12) hour = 0;
                        date = new Date(year, month, day, hour, minute, second);
                    }
                }
                if (isNaN(date.getTime())) return value;

                var map = {
                    'yyyy': date.getFullYear(),
                    'MM': ('0' + (date.getMonth() + 1)).slice(-2),
                    'dd': ('0' + date.getDate()).slice(-2),
                    'HH': ('0' + date.getHours()).slice(-2),
                    'mm': ('0' + date.getMinutes()).slice(-2),
                    'ss': ('0' + date.getSeconds()).slice(-2)
                };
                var result = format;
                for (var key in map) {
                    result = result.replace(key, map[key]);
                }
                return result;
            }
        },
        mounted() { this.jiaZaiShuJu(); },
        methods: {
            jiaZaiShuJu() {
                var self = this;
                var params = new URLSearchParams();
                if (this.tieZiMing) params.append('tieZiMing', this.tieZiMing);
                if (this.tieZiID) params.append('tieZiID', this.tieZiID);
                params.append('page', this.page);
                params.append('pageSize', this.pageSize);

                fetch(`/GuanLi/TieZiLieBiao?${params.toString()}`)
                    .then(res => res.json())
                    .then(data => {
                        self.list = data.list.map(function (item) {
                            return { ...item, ZhuangTai: parseInt(item.ZhuangTai) || 0 };
                        });
                        self.total = data.total;
                        self.totalPages = data.totalPages || 1;
                        self.page = data.page;
                    })
                    .catch(err => {
                        console.error('加载失败', err);
                        self.xianShiXiaoXi('数据加载失败，请稍后重试');
                    })
                    .finally(() => {
                        if (self.firstLoad) setTimeout(() => { self.firstLoad = false; }, 600);
                    });
            },
            souSuo() { this.page = 1; this.jiaZaiShuJu(); },
            qingKong() { this.tieZiMing = ''; this.tieZiID = ''; this.souSuo(); },
            huanYe(p) { if (p < 1 || p > this.totalPages) return; this.page = p; this.jiaZaiShuJu(); },

            kaiQiFengJin(item) {
                this.currentFengJinItem = item;
                this.fengJinYuanYin = '';
                this.showFengJinModal = true;
            },
            guanBiFengJinMoTai() {
                this.showFengJinModal = false;
                this.currentFengJinItem = {};
            },
            zhiXingFengJin() {
                var self = this;
                var formData = new FormData();
                formData.append('tieZiID', self.currentFengJinItem.TieZiID);
                formData.append('yuanYin', self.fengJinYuanYin || '管理操作');
                fetch('/GuanLi/FengJinTieZi', { method: 'POST', body: formData })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            self.guanBiFengJinMoTai();
                            self.jiaZaiShuJu();
                        } else {
                            self.xianShiXiaoXi(data.message || '操作失败');
                        }
                    })
                    .catch(err => {
                        console.error('封禁失败', err);
                        self.xianShiXiaoXi('网络错误，封禁失败');
                    });
            },

            kaiQiJieFeng(item) {
                this.currentJieFengItem = item;
                this.showJieFengModal = true;
            },
            guanBiJieFengMoTai() {
                this.showJieFengModal = false;
                this.currentJieFengItem = {};
            },
            zhiXingJieFeng() {
                var self = this;
                fetch('/GuanLi/JieFengTieZi', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `tieZiID=${self.currentJieFengItem.TieZiID}`
                })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            self.guanBiJieFengMoTai();
                            self.jiaZaiShuJu();
                        } else {
                            self.xianShiXiaoXi(data.message || '操作失败');
                        }
                    })
                    .catch(err => {
                        console.error('解封失败', err);
                        self.xianShiXiaoXi('网络错误，解封失败');
                    });
            },

            // 消息模态框控制
            xianShiXiaoXi(text) {
                this.messageText = text;
                this.showMessageModal = true;
            },
            guanBiXiaoXiMoTai() {
                this.showMessageModal = false;
                this.messageText = '';
            }
        }
    });
</script>