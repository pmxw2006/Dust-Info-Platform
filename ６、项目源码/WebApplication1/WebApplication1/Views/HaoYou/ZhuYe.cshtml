@{
    ViewBag.Title = "ZhuYe";
    Layout = "~/Views/Shared/_YongHu.cshtml";
    int currentUserId = Convert.ToInt32(Session["ID"] ?? 0);
}

@section styles {
    <link href="~/CSS/HaoYou/ZhuYe.css" rel="stylesheet" />
}

<div id="HaoYou" class="liaotian-zhengti" v-cloak>
    <!-- 左侧好友列表 -->
    <div class="ce-bian-lan">
        <div class="qun-liao-biao-ti">私信列表</div>
        <div v-for="item in houyou" :key="item.YongHuIDYI + item.YongHuIDER"
             class="qun-liao-xiang" :class="{ huoyue: getFriendId(item) == dangqianhaoyouid }"
             @@click="dianJiHaoYouLieBiao(getFriendId(item))">
            <div class="touxiang">{{ getFriendName(item).charAt(0) }}</div>
            <span class="haoyou-mingzi">{{ getFriendName(item)}}</span>
        </div>
        <div v-if="houyou.length === 0" style="color:#8fbedc; text-align:center; padding:20px;">暂无好友</div>
    </div>

    <!-- 右侧聊天区域 -->
    <div class="liaotian-qu">
        <div class="liaotian-dingbu">
            {{ currentFriendName || '请选择好友' }}
            <span v-for="i in houyou" v-if="i.YongHuIDYI==dangqianhaoyouid || i.YongHuIDER==dangqianhaoyouid">
                <span v-if="i.YongHuIDYI==@currentUserId" id="1">
                    {{i.GuangZhuZhuangTai==0 ? "" : "临时会话"}}
                </span>
                <span v-if="i.YongHuIDER==@currentUserId" id="2">
                    {{i.HuiGuanZhuangTai==0 ? "" : "临时会话"}}
                </span>
                <span v-if="i.YongHuIDYI==@currentUserId" id="3">
                    <a to="javascript:void(0)" @@click.prevent="GuanzhuYI(i.YongHuIDER, i.GuangZhuZhuangTai)">
                        {{ i.GuangZhuZhuangTai != 0 ? '关注' : '已关注' }}
                    </a>
                </span>
                <span v-if="i.YongHuIDER == @currentUserId" id="4">
                    <a @@click.prevent="GuanzhuER(i.YongHuIDYI, i.HuiGuanZhuangTai)">
                        {{ i.HuiGuanZhuangTai != 0 ? '关注' : '已关注' }}
                    </a>
                </span>
            </span>
        </div>

        <!-- 消息列表 -->
        <div class="xiaoxi-lie" ref="messageBox">
            <div v-for="i in houyou">
                <div v-if="i.YongHuIDYI==dangqianhaoyouid || i.YongHuIDER==dangqianhaoyouid">
                    <div v-if="i.YongHuIDYI==@currentUserId && i.GuangZhuZhuangTai==0 && i.HuiGuanZhuangTai!=0">对方回复或关注你之前，只能发送一条文字消息</div>
                    <div v-if="i.YongHuIDER==@currentUserId && i.GuangZhuZhuangTai!=0 && i.HuiGuanZhuangTai==0">对方回复或关注你之前，只能发送一条文字消息</div>
                </div>
            </div>
            <div v-for="msg in Xinxi" :key="msg.XinXiID"
                 class="xiaoxi-tiao" :class="msg.FaSongZheID == currentUserId ? 'zijid' : 'duifang'">
                <div class="xiaoxi-yonghu" v-if="msg.FaSongZheID != currentUserId">
                    {{ msg.fasongming }}
                </div>
                <div class="xiaoxi-neirong">
                    {{ msg.XinXiNeiRong }}

                </div>
                <div class="xiaoxi-tishi">
                    {{msg.ZhuangTai==2 ?"发送失败":""}}
                </div>
                <div class="xiaoxi-shijian">{{ weixinTime(msg.ChuangJianShiJian) }}</div>
            </div>
            <div v-if="Xinxi.length === 0 && !loadingMessages" style="text-align:center; color:#8fbedc; padding:40px;">
                暂无消息，开始聊天吧～
            </div>
            <div v-if="loadingMessages" style="text-align:center; color:#8fbedc; padding:10px;">加载消息中...</div>
        </div>

        <!-- 输入区域 -->
        <div class="shuru-qu" v-if="dangqianhaoyouid != 0">
            <input type="text" class="shuru-kuang" v-model="XinXiNeirong"
                   @@keyup.enter="FaSongXinXi" placeholder="输入消息..." maxlength="500"
                   :disabled="sending" />
            <button class="fasong-an" @@click="FaSongXinXi" :disabled="sending">发送</button>
        </div>
    </div>

    <!-- 全局加载遮罩（屏幕正中间） -->
    <div class="global-loading-mask" v-if="globalLoading">
        <div class="global-loading-content">
            <div class="global-loading-spinner"></div>
            <div class="global-loading-text">加载中...</div>
        </div>
    </div>
</div>

<script src="https://cdn.bootcdn.net/ajax/libs/vue/2.6.14/vue.min.js"></script>
<script src="https://cdn.bootcdn.net/ajax/libs/vue-router/3.5.3/vue-router.min.js"></script>
<script>

    new Vue({
        el: "#HaoYou",
        router: new VueRouter({
            mode: 'abstract',
            routes: []
        }),
        data: {
            currentUserId: @currentUserId,
            houyou: [],
            dangqianhaoyouid: 0,
            Xinxi: [],
            XinXiNeirong: "",
            sending: false,
            loadingMessages: false,
            globalLoading: false,      // 全局加载遮罩显示标志
            loadingText: "加载中...",  // 可动态显示不同提示文字
            xxid:""
        },
        computed: {
            currentFriendName: function() {
                if (!this.dangqianhaoyouid) return '';
                var friend = this.houyou.find(item => this.getFriendId(item) == this.dangqianhaoyouid);
                return friend ? this.getFriendName(friend) : '';
            }
        },
        created: function () {
            this.loadHaoYouList();
        },
        methods: {
            getFriendId: function(item) {
                return item.YongHuIDYI == this.currentUserId ? item.YongHuIDER : item.YongHuIDYI;
            },
            getFriendName: function(item) {
                return item.YongHuIDYI != this.currentUserId ? item.YongHuERMing : item.YongHuYIMing;
            },
            // 显示全局加载遮罩
            showGlobalLoading: function(text) {
                this.loadingText = text || "加载中...";
                this.globalLoading = true;
            },
            // 隐藏全局加载遮罩
            hideGlobalLoading: function() {
                this.globalLoading = false;
            },
            // 加载好友列表
            loadHaoYouList: function () {
                var self = this;
                self.showGlobalLoading("正在加载好友列表...");
                fetch("/Models/HaoYou/HuoQuHaoYouXinXi.ashx")
                    .then(response => {
                        if (!response.ok) throw new Error("HTTP " + response.status);
                        return response.json();
                    })
                    .then(data => {
                        self.houyou = data || [];
                        self.hideGlobalLoading();
                        console.log(self.houyou);
                    })
                    .catch(error => {
                        console.error("加载好友列表失败:", error);
                        self.hideGlobalLoading();
                        alert("加载好友列表失败，请刷新页面重试");
                    });
            },
            dianJiHaoYouLieBiao: function (friendId) {
                console.log("点击好友ID:", friendId);
                if (!friendId) return;
                if (this.dangqianhaoyouid === friendId) return;
                this.dangqianhaoyouid = friendId;
                this.loadMessages(friendId);
                this.XinXiNeirong = "";
            },
            // 加载消息（使用局部加载状态）
            loadMessages: function (friendId) {
                var self = this;
                self.loadingMessages = true;
                fetch("/Models/HaoYou/XinXiGuanLi.ashx", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ YongHuID: friendId })
                })
                    .then(response => {
                        if (!response.ok) throw new Error("HTTP " + response.status);
                        return response.json();
                    })
                    .then(data => {
                        self.Xinxi = Array.isArray(data) ? data : [];
                        self.$nextTick(() => {
                            var box = self.$refs.messageBox;
                            if (box) box.scrollTop = box.scrollHeight;
                        });
                    })
                    .catch(error => {
                        console.error("加载消息失败:", error);
                        alert("加载消息失败，请稍后重试");
                        self.Xinxi = [];
                    })
                    .finally(() => {
                        self.loadingMessages = false;
                    });
            },
            FaSongXinXi: function () {
                var self = this;
                var content = self.XinXiNeirong.trim();
                if (content === "") {
                    return;
                }
                if (self.sending) return;
                self.sending = true;

                fetch("/Models/HaoYou/XinXiGuanLi.ashx", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        YongHuID: self.dangqianhaoyouid,
                        NeiRong: content,
                    })
                })
                .then(response => {
                    if (!response.ok) throw new Error("HTTP " + response.status);
                    return response.json();
                })
                .then(res => {
                    if (res.success === true) {
                        self.XinXiNeirong = "";
                        self.loadMessages(self.dangqianhaoyouid);
                    } else {
                        self.XinXiNeirong = "";
                        self.loadMessages(self.dangqianhaoyouid);
                    }
                })
                .catch(error => {
                    console.error("发送消息失败:", error);
                    self.Error = "发送失败"
                })
                .finally(() => {
                    self.sending = false;
                });
            },
            weixinTime(str) {
                if (!str) return '';
                // 处理 /Date(毫秒数)/ 这种格式
                var match = str.match(/\/Date\((\d+)\)\//);
                if (match) {
                    str = parseInt(match[1]);
                }
                var d = new Date(str);
                if (isNaN(d.getTime())) return str;
                var now = new Date();
                var today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
                var yesterday = new Date(today.getTime() - 86400000);
                var msgDate = new Date(d.getFullYear(), d.getMonth(), d.getDate());

                var time = d.getHours().toString().padStart(2, '0') + ':' +
                    d.getMinutes().toString().padStart(2, '0');
                if (msgDate.getTime() === today.getTime()) {
                    return time;
                } else if (msgDate.getTime() === yesterday.getTime()) {
                    return '昨天 ' + time;
                } else {
                    var month = (d.getMonth() + 1).toString().padStart(2, '0');
                    var day = d.getDate().toString().padStart(2, '0');
                    return month + '/' + day + ' ' + time;
                }
            },
            GuanzhuYI: function (id,zhuangtai) {
                const _self = this;
                fetch("/Models/HaoYou/XiuGaiZhuangTai.ashx", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({ YongHuIDER: id, ZhuangTai: zhuangtai })
                }).then(p => p.json())
                    .then(p => {
                        if (p.success) {
                            this.loadHaoYouList();
                            _self.loadMessages(_self.dangqianhaoyouid)
                        }
                    })
            },
            GuanzhuER: function (id, zhuangtai) {
                const _self = this;
                fetch("/Models/HaoYou/XiuGaiZhuangTai.ashx", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({ YongHuIDYI: id, ZhuangTai: zhuangtai })
                }).then(p => p.json())
                    .then(p => {
                        if (p.success) {
                            this.loadHaoYouList();
                            _self.loadMessages(_self.dangqianhaoyouid)
                        }
                    })
            }
        }
    });
</script>