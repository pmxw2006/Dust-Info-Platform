@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_YongHu.cshtml";
}
<link href="~/CSS/YngHu/ShouYie.css" rel="stylesheet" type="text/css" />

<div id="ZhuTi">
    <div id="NeiRong">
        <div id="NeiRong">
            <!-- 加载中状态 -->
            <div v-if="isLoading" class="loading-container">
                <div class="loading-spinner"></div>
                <p class="loading-text">加载中，请稍候...</p>
            </div>

            <!-- 加载完成，显示列表 -->
            <template v-else>
                <div class="card-list" v-for="(item, index) in list" :key="item.t.TieZiID">
                    <a :href="'/YongHu/TieZiNeiRong?id=' + item.t.TieZiID">
                        <div class="card-list-left">
                            <img :src="'/Img/'+item.Lujing" />
                        </div>
                        <div class="card-list-right">
                            <div class="list-Top">
                                <p class="bt">{{item.t.TieZiMing}}</p>
                                <p class="yh">{{item.t.YongHuMing}}</p>
                            </div>
                            <div class="list-Footer">
                                <p class="time">{{item.t.FaBuShiJian}}</p>
                            </div>
                        </div>
                    </a>
                </div>
                <!-- 如果没有数据，可增加提示 -->
                <div v-if="list.length === 0" class="no-data">暂无帖子</div>
                <!-- 分页区域 -->
                <div id="FanYe">
                    <div class="pagination">
                        <input type="button" value="首页" v-on:click="DiYiYe()" />
                        <input type="button" :disabled="disabledPrev" value="上一页" v-on:click="ShangYiTie()" />
                        <span style="line-height: 40px;">第 {{ currentPage }} / {{ totalPages }} 页</span>
                        <input type="button" :disabled="disabledNext" value="下一页" v-on:click="XiaYiYie()" />
                        <input type="button" value="尾页" v-on:click="MoWei()" />
                    </div>
                </div>
            </template>
        </div>
    </div>

    
</div>

<script src="https://cdn.bootcdn.net/ajax/libs/vue/2.6.14/vue.min.js"></script>
<script>
    var app = new Vue({
        el: "#ZhuTi",
        data: {
            list: [],          // 当前页数据
            currentPage: 1,    // 当前页码
            pageSize: 10,      // 每页条数
            total: 0,          // 总记录数
            totalPages: 0,      // 总页数
            disabledPrev: true,     //上一页是否可以点击
            disabledNext: false,//下一页是否可以点击
            isLoading: true//是否为正在加载中
        },
        created: function () {
            this.loadPage(1);
        },
        methods: {
            loadPage: function (page) {
                var self = this;
                fetch(`/Models/YongHuB/TieZiHandler.ashx?page=${page}&pageSize=${self.pageSize}`)
                    .then(res => res.json())
                    .then(data => {
                        console.log("后端返回数据：", data);
                        // 转换日期格式
                        self.list = data.list.map(item => {
                            if (item.t && item.t.FaBuShiJian) {
                                const timestamp = parseInt(item.t.FaBuShiJian.replace(/\D/g, ''));
                                const date = new Date(timestamp);
                                const year = date.getFullYear();
                                const month = String(date.getMonth() + 1).padStart(2, '0');
                                const day = String(date.getDate()).padStart(2, '0');
                                item.t.FaBuShiJian = `${year}-${month}-${day}`;
                            }
                            return item;
                        });
                        self.currentPage = data.page;
                        self.total = data.total;
                        //总页数
                        self.totalPages = Math.ceil(data.total / data.pageSize);
                        //判断上一页和下一页是否可点击
                        //上一页不可点击条件：当前页为第一页
                        self.disabledPrev = (self.currentPage === 1);
                        //下一页不可点击条件：当前页为最后页
                        self.disabledNext = (self.currentPage === self.totalPages);
                    }).catch(err => {
                        console.error("数据加载失败", err);
                    })
                    .finally(() => {
                        self.isLoading = false;  // 无论成功与否，结束 loading
                    });
            },
            //上一页
            ShangYiTie: function () {
                if (this.currentPage > 1) {
                    this.loadPage(this.currentPage - 1);
                }
            },
            //下一页
            XiaYiYie: function () {
                if (this.currentPage < this.totalPages) {
                    this.loadPage(this.currentPage + 1);
                }
            },
            ///跳转首页
            DiYiYe: function () {
                this.loadPage(1);
            },
            //跳转末页
            MoWei: function () {
                this.loadPage(this.totalPages);
            }
        }
    });
</script>